FROM hf.co/unsloth/Qwen3.5-9B-MTP-GGUF:UD-Q4_K_XL

# Source verified 2026-06-30: this repo's HF OCI config-blob endpoint
# fetches in ~130 ms (3/3), unlike the sibling unsloth/Qwen3.5-9B-GGUF
# whose endpoint hangs indefinitely.  Ollama's official library has no
# CUDA Qwen3.5-9B-MTP tag (only Apple-MLX variants), so HF is the only
# source.  If the OCI bridge breaks here too, the non-MTP fallback is
# the already-staged Modelfile.qwen3.5-9b-coding-q4-k-m (Ollama
# official qwen3.5:9b).  See memory
# unsloth_qwen3.5_oci_bridge_broken.md.

# --- CONTEXT CALIBRATION ---
# Native context is 256K (262144), so 131072 stays within native — no YaRN.
# Gated-DeltaNet hybrid (24 linear + 8 full-attn layers) keeps the KV cache
# small, easing the 12 GB RTX 4070 budget at long ctx.
PARAMETER num_ctx 131072
PARAMETER num_predict 65536

# --- SPECULATIVE DECODING (MTP) ---
# GGUF has embedded MTP tensors; Ollama auto-detects and self-drafts.
# Unsloth's recommended starting value (--spec-draft-n-max 2).
PARAMETER draft_num_predict 2

# --- QWEN 3.5 "PRECISE CODING" PROFILE (thinking mode) ---
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 20

# --- LOGIC PROTECTION ---
# Qwen 3.5/3.6 docs mandate repeat_penalty 1.0; any other value causes
# structural garbage in code output.
PARAMETER repeat_penalty 1.0

# --- SAMPLING FIDELITY ---
PARAMETER min_p 0.0
PARAMETER presence_penalty 0.0
