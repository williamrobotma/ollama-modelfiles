FROM qwen3.5:9b

# Source: Ollama official library (registry.ollama.ai/library/qwen3.5:9b),
# Q4_K_M, ~6.6 GB.  Previously sourced from
# hf.co/unsloth/Qwen3.5-9B-GGUF:UD-Q4_K_XL until HF's OCI config blob
# endpoint started hanging indefinitely for that repo (verified repo-wide,
# every tag, 7+ days persistent).  Switched to the Ollama registry for
# durable re-pulls; ~1-2% quality drop vs Unsloth Dynamic 2.0 (UD-Q4_K_XL).
# Recheck Unsloth periodically — see memory
# unsloth_qwen3.5_oci_bridge_broken.md.

# --- CONTEXT CALIBRATION ---
# Native context is 256K (262144), so 131072 stays within native — no YaRN.
# Gated-DeltaNet hybrid (24 linear + 8 full-attn layers) keeps the KV cache
# small, easing the 12 GB RTX 4070 budget at long ctx.
PARAMETER num_ctx 131072
PARAMETER num_predict 65536


# --- QWEN 3.5 "PRECISE CODING" PROFILE (thinking mode) ---
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 20

# --- LOGIC PROTECTION ---
# Qwen 3.5/3.6 docs mandate repeat_penalty 1.0; any other value causes
# structural garbage in code output.
PARAMETER repeat_penalty 1.0

# --- SAMPLING FIDELITY ---
PARAMETER min_p 0.0
PARAMETER presence_penalty 0.0
